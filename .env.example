# =========================================
# Socria — environment variables
# Copy this file to .env.local and fill in.
# NEVER commit .env.local
# =========================================

# --- OpenAI (server-side only) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Supabase ---
# Found in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
# Service role key — SERVER ONLY. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=ey...

# --- Clerk auth ---
# From your Clerk dashboard: API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirects (defaults are fine)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe (optional, scaffolded for later) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Rate limit (simple per-user daily cap) ---
DAILY_MESSAGE_LIMIT=100
